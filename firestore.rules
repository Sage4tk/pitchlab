rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users may only access their own subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progress sub-collection: validate shape on write.
    match /users/{userId}/progress/{attemptId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['category', 'correct', 'createdAt'])
        && request.resource.data.correct is bool
        && request.resource.data.createdAt is number;
      // Progress records are immutable once written.
      allow update, delete: if false;
    }

    // Streak: validate shape on write.
    match /users/{userId}/streak/current {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['current', 'longest', 'lastSession'])
        && request.resource.data.current is int
        && request.resource.data.longest is int
        && request.resource.data.lastSession is string
        // Streak can only go up or reset to 1 — never negative.
        && request.resource.data.current >= 0
        && request.resource.data.longest >= 0;
    }

    // XP: validate shape and prevent client-side XP inflation.
    match /users/{userId}/stats/xp {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['totalXP'])
        && request.resource.data.totalXP is int
        && request.resource.data.totalXP >= 0;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['totalXP'])
        && request.resource.data.totalXP is int
        // XP can only increase, never decrease.
        && request.resource.data.totalXP >= resource.data.totalXP
        // Cap per-write increment to 100 XP (one exercise session max).
        && request.resource.data.totalXP - resource.data.totalXP <= 100;
    }

    // Courses: validate shape on write.
    match /users/{userId}/courses/{courseId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['courseId'])
        && request.resource.data.courseId == courseId;
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
